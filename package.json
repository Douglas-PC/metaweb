{
  "name": "metaverse13",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "prebuild": "node scripts/verify-env.js",
    "export": "next build",
    "start": "next start",
    "lint": "next lint",
    "analyze": "cross-env ANALYZE=true next build",
    "perf:report": "node scripts/bundle-report.js",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:a11y": "jest --testPathPattern=a11y",
    "test:ci": "npm run test && npm run test:a11y",
    "clean": "powershell -Command \"Remove-Item -Recurse -Force .next,out -ErrorAction SilentlyContinue\"",
    "sitemap": "node scripts/generate-sitemap.js",
    "robots": "node scripts/generate-robots.js",
    "browserslist:update": "npx update-browserslist-db@latest --update-db",
    "audit": "npm audit --audit-level=moderate || true",
    "postinstall": "node scripts/postinstall.js || echo 'postinstall skipped'"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^15.4.6",
    "eslint-config-next": "15.4.6",
    "framer-motion": "^12.23.18",
    "gray-matter": "^4.0.3",
    "marked": "^12.0.2",
    "next": "^15.4.6",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "autoprefixer": "^10.4.20",
    "axe-core": "^4.9.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.57.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jsx-a11y": "^6.8.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jest": "^29.7.0",
    "jest-axe": "^9.0.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.39",
    "source-map-explorer": "^2.5.3",
    "tailwindcss": "^3.4.17"
  },
  "overrides": {},
  "browserslist": [
    ">0.5%",
    "last 2 versions",
    "not dead",
    "not ie <= 11"
  ]
}
